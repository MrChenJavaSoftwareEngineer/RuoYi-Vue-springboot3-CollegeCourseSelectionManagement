<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.学生Mapper">
    
    <resultMap type="学生" id="学生Result">
        <result property="学号"    column="学号"    />
        <result property="年级"    column="年级"    />
        <result property="姓名"    column="姓名"    />
        <result property="用户类型"    column="用户类型"    />
        <result property="专业"    column="专业"    />
        <result property="逻辑删除"    column="逻辑删除"    />
    </resultMap>

    <sql id="select学生Vo">
        select 学号, 年级, 姓名, 用户类型, 专业, 逻辑删除 from 学生
    </sql>

    <select id="select学生List" parameterType="学生" resultMap="学生Result">
        <include refid="select学生Vo"/>
        <where>  
            <if test="年级 != null "> and 年级 = #{年级}</if>
            <if test="姓名 != null  and 姓名 != ''"> and 姓名 = #{姓名}</if>
            <if test="用户类型 != null  and 用户类型 != ''"> and 用户类型 = #{用户类型}</if>
            <if test="专业 != null  and 专业 != ''"> and 专业 = #{专业}</if>
            <if test="逻辑删除 != null "> and 逻辑删除 = #{逻辑删除}</if>
        </where>
    </select>
    
    <select id="select学生By学号" parameterType="String" resultMap="学生Result">
        <include refid="select学生Vo"/>
        where 学号 = #{学号}
    </select>

    <insert id="insert学生" parameterType="学生">
        insert into 学生
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="学号 != null">学号,</if>
            <if test="年级 != null">年级,</if>
            <if test="姓名 != null and 姓名 != ''">姓名,</if>
            <if test="用户类型 != null">用户类型,</if>
            <if test="专业 != null and 专业 != ''">专业,</if>
            <if test="逻辑删除 != null">逻辑删除,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="学号 != null">#{学号},</if>
            <if test="年级 != null">#{年级},</if>
            <if test="姓名 != null and 姓名 != ''">#{姓名},</if>
            <if test="用户类型 != null">#{用户类型},</if>
            <if test="专业 != null and 专业 != ''">#{专业},</if>
            <if test="逻辑删除 != null">#{逻辑删除},</if>
         </trim>
    </insert>

    <update id="update学生" parameterType="学生">
        update 学生
        <trim prefix="SET" suffixOverrides=",">
            <if test="年级 != null">年级 = #{年级},</if>
            <if test="姓名 != null and 姓名 != ''">姓名 = #{姓名},</if>
            <if test="用户类型 != null">用户类型 = #{用户类型},</if>
            <if test="专业 != null and 专业 != ''">专业 = #{专业},</if>
            <if test="逻辑删除 != null">逻辑删除 = #{逻辑删除},</if>
        </trim>
        where 学号 = #{学号}
    </update>

    <delete id="delete学生By学号" parameterType="String">
        delete from 学生 where 学号 = #{学号}
    </delete>

    <delete id="delete学生By学号s" parameterType="String">
        delete from 学生 where 学号 in 
        <foreach item="学号" collection="array" open="(" separator="," close=")">
            #{学号}
        </foreach>
    </delete>
</mapper>